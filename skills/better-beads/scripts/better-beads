  "tool": "better-beads",
  "version": "$VERSION",
  "contract_version": "$CONTRACT_VERSION",
  "summary": "Unified dispatcher for Better Beads quality, routing, dispatch, and closeout commands.",
  "stdout": "Delegated command output or requested machine-readable JSON only.",
