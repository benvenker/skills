{
  "name": "better-beads",
  "version": "1.0.0",
  "description": "Beads authoring, review, routing, quality-gate, dispatch, and closeout helper skill for creating behavior-first execution contracts.",
  "author": "Ben Venker",
  "triggers": [
    "converting plans or PRDs into beads",
    "reviewing bead quality",
    "fixing bad bead graphs",
    "preparing beads for multi-agent implementation"
  ],
  "exclusions": [
    "general-purpose issue tracking outside Beads",
    "feature implementation for beads produced by the skill",
    "broad code rewrites unrelated to Beads authoring or graph quality",
    "interactive TUI operation when robot-mode surfaces are available"
  ],
  "required_tools": [
    "br",
    "bv",
    "python3",
    "bash"
  ],
  "risk_level": "medium",
  "resources": [
    {
      "path": "SKILL.md",
      "description": "Primary skill entrypoint and workflow rules."
    },
    {
      "path": "metadata.json",
      "description": "Canonical dependency, compatibility, trigger, and exclusion metadata."
    },
    {
      "path": "PORTABILITY.md",
      "description": "Portability boundary for docs, examples, scripts, schemas, and Beads-specific gates."
    },
    {
      "path": "schemas/README.md",
      "description": "Inventory of covered and deferred robot output schemas."
    },
    {
      "path": "references/README.md",
      "description": "Reference reading order for authoring, routing, quality, graph construction, and semantic review."
    }
  ],
  "scripts": [
    {
      "path": "scripts/better-beads",
      "description": "Unified dispatcher for Better Beads robot surfaces and delegated commands."
    },
    {
      "path": "scripts/bead_route.sh",
      "description": "Inspection-first route helper for graph state and plan-readiness recommendations."
    },
    {
      "path": "scripts/bead_gate_loop.sh",
      "description": "Operator gate runner and dispatch-verdict producer."
    },
    {
      "path": "scripts/bead_quality_gate.py",
      "description": "Deterministic Beads execution-contract quality gate."
    },
    {
      "path": "scripts/bead_closeout_guard.sh",
      "description": "Closeout guard for unexpected in-progress beads."
    },
    {
      "path": "scripts/bead_create_graph.py",
      "description": "Graph draft dry-run and apply helper."
    },
    {
      "path": "scripts/test_schemas.sh",
      "description": "Offline schema and producer contract validation harness."
    }
  ],
  "surfaces": [
    {
      "command": "scripts/better-beads capabilities --json",
      "description": "Dispatcher capability inventory.",
      "mutates_repo": false,
      "requires_tools": [
        "bash"
      ],
      "stdout_schema": "capabilities-v1",
      "stdout_schema_status": "deferred"
    },
    {
      "command": "scripts/better-beads robot-docs guide",
      "description": "Dispatcher robot usage guide.",
      "mutates_repo": false,
      "requires_tools": [
        "bash"
      ],
      "stdout_schema": "markdown-guide-v1",
      "stdout_schema_status": "markdown"
    },
    {
      "command": "scripts/better-beads triage --json",
      "description": "Dispatcher triage summary.",
      "mutates_repo": false,
      "requires_tools": [
        "br",
        "bv",
        "python3",
        "bash"
      ],
      "stdout_schema": "better-beads-triage-v1",
      "stdout_schema_status": "deferred"
    },
    {
      "command": "scripts/better-beads authoring-triage --json",
      "description": "Stable first agent-readable packet for route, graph inspection, mutation eligibility, and next commands.",
      "mutates_repo": false,
      "requires_tools": [
        "br",
        "bv",
        "python3",
        "bash"
      ],
      "stdout_schema": "better-beads-authoring-triage-v1",
      "stdout_schema_status": "covered",
      "stdout_schema_path": "schemas/better-beads-authoring-triage-v1.schema.json"
    },
    {
      "command": "scripts/better-beads route --json",
      "description": "Dispatcher route recommendation delegated to bead_route.sh.",
      "mutates_repo": false,
      "requires_tools": [
        "br",
        "bv",
        "bash"
      ],
      "stdout_schema": "better-beads-route-v1",
      "stdout_schema_status": "covered",
      "stdout_schema_path": "schemas/better-beads-route-v1.schema.json"
    },
    {
      "command": "scripts/better-beads route --plan PATH --json",
      "description": "Dispatcher route recommendation with raw plan readiness inspection.",
      "mutates_repo": false,
      "requires_tools": [
        "br",
        "bv",
        "bash"
      ],
      "stdout_schema": "better-beads-route-v1",
      "stdout_schema_status": "covered",
      "stdout_schema_path": "schemas/better-beads-route-v1.schema.json"
